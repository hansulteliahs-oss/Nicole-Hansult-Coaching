# ─── Phase 1 — required for local dev ───
NEXT_PUBLIC_SITE_URL=                   # e.g. https://nicole-hansult-coaching.vercel.app
DEV_PREVIEW_KEY=                        # any string; gate for /dev/components (Plan 02)

# ─── Phase 3 — Resend (transactional + lead magnet) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=                      # Nicole <nicole@mail.nicolehansultcoaching.com>

# ─── Phase 3 — Vercel Blob (lead-magnet PDF storage) ───
BLOB_READ_WRITE_TOKEN=                  # from Vercel Dashboard → Storage → Blob
BLOB_PDF_URL=                           # printed by scripts/upload-pdf.ts after one-time upload

# ─── Phase 3/4 — Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=                    # server only — NEVER NEXT_PUBLIC_

# ─── Phase 5 — Stripe ───
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET_LIVE=
STRIPE_WEBHOOK_SECRET_TEST=

# ─── Phase 5 — Mux ───
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=

# ─── Phase 5/6 — Sentry ───
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
