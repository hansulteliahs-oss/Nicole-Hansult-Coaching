# ─── Phase 1 — required for local dev ───
NEXT_PUBLIC_SITE_URL=                   # e.g. https://nicole-hansult-coaching.vercel.app
DEV_PREVIEW_KEY=                        # any string; gate for /dev/components (Plan 02)

# ─── Phase 3 — Resend (transactional + lead magnet) ───
RESEND_API_KEY=
RESEND_FROM_EMAIL=                      # Nicole <nicole@mail.nicolehansultcoaching.com>

# ─── Phase 3 — Vercel Blob (lead-magnet PDF storage) ───
BLOB_READ_WRITE_TOKEN=                  # from Vercel Dashboard → Storage → Blob
BLOB_PDF_URL=                           # printed by scripts/upload-pdf.ts after one-time upload

# ─── Phase 3/4 — Supabase ───
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=                    # server only — NEVER NEXT_PUBLIC_

# ─── Phase 5: Paywall + Course (Stripe + Mux + Sentry) ───

# Stripe — pay-first checkout for Vibrant40 ($88 one-time)
STRIPE_SECRET_KEY=                      # sk_test_... (dev) / sk_live_... (prod)
STRIPE_PUBLISHABLE_KEY=                 # pk_test_... / pk_live_...
STRIPE_PRICE_VIBRANT40=                 # price_xxx — created in Stripe Dashboard (Plan 02)
STRIPE_WEBHOOK_SECRET_LIVE=             # Dashboard → Webhooks → Signing secret (live mode)
STRIPE_WEBHOOK_SECRET_TEST=             # Dashboard → Webhooks → Signing secret (test mode)
STRIPE_WEBHOOK_SECRET_CLI=              # whsec_... printed by `stripe listen` (local dev only)

# Mux — signed playback for Vibrant40 video lessons (6h JWT TTL, per-render mint)
MUX_TOKEN_ID=                           # Mux Dashboard → Settings → Access Tokens
MUX_TOKEN_SECRET=                       # shown once at token creation
MUX_SIGNING_KEY_ID=                     # Mux Dashboard → Settings → Signing Keys
MUX_SIGNING_PRIVATE_KEY=                # base64-encoded PEM, shown once at key creation

# Sentry — production-only error capture (disabled in NODE_ENV !== '''production''')
SENTRY_DSN=                             # Sentry → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=                 # same DSN; exposed to the browser bundle
SENTRY_AUTH_TOKEN=                      # Sentry → Settings → Auth Tokens (project:read + project:releases)
